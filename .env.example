VITE_AUDIUS_BEARER_TOKEN=your_bearer_token_here
VITE_AUDIUS_APP_NAME=StreamVault
# For Log in with Audius (OAuth): get API key from https://audius.co/settings → Manage Your Apps
VITE_AUDIUS_API_KEY=
VITE_AO_MU_URL=https://tee-6.forward.computer
VITE_AO_CU_URL=https://forward.computer
VITE_AO_GATEWAY_URL=https://arweave.net
VITE_AO_GQL_URL=https://ao-search-gateway.goldsky.com/graphql
VITE_AO_MUSIC_REGISTRY_PROCESS=
VITE_AO_LICENSE_ENGINE_PROCESS=
VITE_AO_ROYALTY_PROCESS=

# Spotify catalog search is OFF by default (no UI, no browser calls to /api/spotify-search).
# To enable: set VITE_SPOTIFY_CATALOG=1, add server credentials below, run `npm run spotify:dev-api` in a second terminal for local Vite, then `npm run dev`. See README + docs/spotify-catalog-search.md.
# VITE_SPOTIFY_CATALOG=1

# Spotify public catalog search — server only (never prefix with VITE_). Used when the feature is enabled.
# Vercel: api/spotify-search.ts. Local dev: scripts/spotify-search-dev.mjs (npm run spotify:dev-api).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
